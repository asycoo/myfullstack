generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  posts     Post[]
  sessions  Session[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** 文章标签：slug 唯一；纯中文等无法生成 ASCII slug 时为 `t-{hash}`，用 label 展示原文 */
model Tag {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  label     String?
  postTags  PostTag[]
  createdAt DateTime  @default(now())
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model Post {
  id                  Int       @id @default(autoincrement())
  slug                String    @unique
  title               String
  content             String?
  excerpt             String?
  coverImage          String?
  readingTimeMinutes  Int       @default(1)
  published           Boolean   @default(false)
  authorId            Int
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postTags  PostTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([authorId])
  /** Public list: WHERE published ORDER BY createdAt DESC */
  @@index([published, createdAt])
}

model Session {
  id        String   @id
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  csrfToken String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}